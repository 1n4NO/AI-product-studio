{
  "name": "product-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Product Studio",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "dev": "npm run --workspace @product-studio/studio-web dev",
    "lint": "npm run --workspaces lint",
    "test": "npm run --workspaces test",
    "typecheck": "npm run --workspaces typecheck"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
