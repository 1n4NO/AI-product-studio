# Product Studio environment template
# Copy this file to `.env.local` (local dev) or your environment-specific secret store.

# Runtime environment selector
# Allowed: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Application base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API endpoint used by studio-web (if separate service is introduced)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Internal API auth between services (server-side only)
INTERNAL_API_KEY=replace_me

# Optional observability endpoint (server-side only)
OTEL_EXPORTER_OTLP_ENDPOINT=
